{
  "name": "on-demand-news-finder",
  "version": "1.0.0",
  "description": "On-Demand News Finder for Signnith Stock Analysis Platform",
  "main": "server.js",
  "type": "module",
  "scripts": {
    "dev": "concurrently --kill-others \"npm run dev:backend\" \"npm run dev:frontend\"",
